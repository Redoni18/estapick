DATABASE_URL="postgresql://postgres:postgres@localhost:5432/estapick"
PORT=3001
SWAGGER_ENABLED=true

# Rate limiting (per-IP, in-memory).
# Read bucket covers GET /listings*; write bucket covers POST /listings.
# /api/health is exempt. Set THROTTLE_ENABLED=false to disable entirely.
THROTTLE_ENABLED=true
THROTTLE_READ_TTL=60
THROTTLE_READ_LIMIT=120
THROTTLE_WRITE_TTL=60
THROTTLE_WRITE_LIMIT=10
